# ======================================================
# CLOUD MODE EXAMPLE (.env cloud)
# ======================================================
# DEPLOY_MODE=cloud
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://developer:masterkey@localhost:5432/Servctl?sslmode=disable
# JWT_SECRET=your-super-secret-key-change-this-in-production
# JWT_EXPIRES_IN=7d
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# FRONTEND_URL=https://servctl.dev
# PORT=3000
# NODE_ENV=production
# CORS_ORIGIN=https://servctl.dev
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@servctl.dev

# ======================================================
# LOCAL MODE EXAMPLE (.env local)
# ======================================================
DEPLOY_MODE=local
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./prisma/servctl.db
JWT_SECRET=local-secret-change-me
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
FRONTEND_URL=http://localhost:5173
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@servctl.dev
