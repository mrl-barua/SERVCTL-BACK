# ===================================================
# SERVCTL Environment Configuration
# Copy to .env and fill in your values
# ===================================================

# -- Ports ------------------------------------------------
FRONTEND_PORT=80
BACKEND_PORT=3000

# -- URLs -------------------------------------------------
FRONTEND_URL=http://localhost
VITE_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost

# -- Runtime mode -----------------------------------------
DEPLOY_MODE=local
SERVCTL_MODE=local

# -- Security (required) ----------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ENCRYPTION_SECRET=
# Backend currently reads ENCRYPTION_KEY (64 hex chars).
ENCRYPTION_KEY=

# -- SSH keys (local mode only) ---------------------------
# Directory on host containing SSH key files.
# Mounted read-only into /home/servctl/.ssh in backend container.
SSH_KEYS_DIR=~/.ssh

# -- Database ---------------------------------------------
# Local mode: provider=sqlite and file URL under /app/data
# Cloud mode: provider=postgresql and compose builds DATABASE_URL
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:/app/data/servctl.db
POSTGRES_DB=servctl
POSTGRES_USER=servctl
POSTGRES_PASSWORD=

# -- Email / SMTP -----------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@servctl.dev

# -- SSO (cloud mode only, optional) ----------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback
