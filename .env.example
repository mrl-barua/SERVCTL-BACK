# Database
# For Docker Compose (recommended for development)
DATABASE_URL=postgresql://developer:masterkey@localhost:5432/Servctl?sslmode=disable

# For Production/Remote PostgreSQL (e.g., Neon.tech)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=*

# Frontend URL used in reset email links
FRONTEND_URL=http://localhost:5173

# SMTP Configuration (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@servctl.dev
