# =======================================================
# SERVCTL Production Environment
# Copy to .env and fill in all required values
# =======================================================

# -- GHCR Authentication ---------------------------------
# Required to pull the private backend image
# Create a GitHub PAT at:
#   github.com/settings/tokens -> New token -> read:packages
GHCR_TOKEN=
GHCR_USERNAME=mrl-barua

# -- Mode ------------------------------------------------
SERVCTL_MODE=local            # local | cloud
VITE_SERVCTL_MODE=local

# -- URLs ------------------------------------------------
# Set to your domain or server IP
FRONTEND_URL=http://localhost
VITE_API_URL=/api

# -- Ports -----------------------------------------------
FRONTEND_PORT=80
BACKEND_PORT=3000

# -- Security -- REQUIRED --------------------------------
# Generate both with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
ENCRYPTION_SECRET=

# -- Database --------------------------------------------
# Local mode (default - SQLite inside container)
DATABASE_URL=file:/app/data/servctl.db

# Cloud mode (uncomment and fill in)
# DATABASE_URL=postgresql://user:password@host:5432/servctl

# PostgreSQL (if using local postgres service)
# POSTGRES_DB=servctl
# POSTGRES_USER=servctl
# POSTGRES_PASSWORD=

# -- SSH Keys --------------------------------------------
# Directory on HOST containing SSH key files
# Mounted read-only into backend container
SSH_KEYS_DIR=~/.ssh

# -- Email - optional ------------------------------------
# For password reset emails
# Use Ethereal for testing: https://ethereal.email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@servctl.dev

# -- SSO - optional --------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback

# -- Image Tags ------------------------------------------
# Use 'latest' or pin to a specific sha tag for stability
# e.g. BACKEND_TAG=sha-a1b2c3d
FRONTEND_TAG=latest
BACKEND_TAG=latest
