// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String
  name                String
  createdAt           DateTime             @default(now())
  servers             Server[]
  sshKeyVault         SshKeyVault[]
  passwordResetTokens PasswordResetToken[]
}

model Server {
  id            Int          @id @default(autoincrement())
  name          String
  host          String
  user          String       @default("ubuntu")
  port          Int          @default(22)
  env           String       @default("prod")
  notes         String?
  deploy        String?
  logPath       String?
  logType       String       @default("file")
  dockerName    String?
  authMethod    String       @default("password")
  passwordEnc   String?
  sshKeyEnc     String?
  sshKeyLabel   String?
  sshKeyPath    String?
  sshKeyVaultId String?
  networkType   String       @default("auto")
  status        String       @default("unknown")
  uptime        Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId       Int
  sshKeyVault   SshKeyVault? @relation(fields: [sshKeyVaultId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([sshKeyVaultId])
}

model SshKeyVault {
  id            String   @id @default(cuid())
  userId        Int
  label         String
  publicKey     String
  privateKeyEnc String
  fingerprint   String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  servers       Server[]

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
