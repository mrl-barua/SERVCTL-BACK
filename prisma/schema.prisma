// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String?
  name                String
  provider            String?
  providerId          String?
  avatar              String?
  createdAt           DateTime             @default(now())
  servers             Server[]
  quickCommands       QuickCommand[]
  sshKeyVault         SshKeyVault[]
  passwordResetTokens PasswordResetToken[]
  authCodes           AuthCode[]
  serverGroups        ServerGroup[]
  serverTags          ServerTag[]
  displayOrders       ServerDisplayOrder[]
  healthAlerts        HealthAlert[]

  @@unique([provider, providerId])
}

model Server {
  id            Int          @id @default(autoincrement())
  name          String
  host          String
  user          String       @default("ubuntu")
  port          Int          @default(22)
  env           String       @default("prod")
  notes         String?
  deploy        String?
  logPath       String?
  logType       String       @default("file")
  dockerName    String?
  authMethod    String       @default("password")
  passwordEnc   String?
  sshKeyEnc     String?
  sshKeyLabel   String?
  sshKeyPath    String?
  sshKeyVaultId String?
  networkType   String       @default("auto")
  status        String       @default("unknown")
  uptime        Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId       Int
  sshKeyVault      SshKeyVault?            @relation(fields: [sshKeyVaultId], references: [id], onDelete: SetNull)
  quickCommands    QuickCommand[]
  groupMemberships ServerGroupMembership[]
  tagAssignments   ServerTagAssignment[]
  healthSnapshots  ServerHealthSnapshot[]
  displayOrders    ServerDisplayOrder[]
  healthAlerts     HealthAlert[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([ownerId, env])
  @@index([sshKeyVaultId])
}

model QuickCommand {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  command   String
  scope     String   @default("all")
  serverId  Int?
  server    Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  icon      String?
  sortOrder Int      @default(0)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([serverId])
  @@index([userId, sortOrder])
}

model SshKeyVault {
  id            String   @id @default(cuid())
  userId        Int
  label         String
  publicKey     String
  privateKeyEnc String
  fingerprint   String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  servers       Server[]

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     Int
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ── Server Groups ──────────────────────────────────────

model ServerGroup {
  id        Int                     @id @default(autoincrement())
  name      String
  color     String                  @default("#4f8ef7")
  sortOrder Int                     @default(0)
  ownerId   Int
  owner     User                    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members   ServerGroupMembership[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([ownerId])
  @@index([ownerId, sortOrder])
}

model ServerGroupMembership {
  id        Int         @id @default(autoincrement())
  serverId  Int
  server    Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  groupId   Int
  group     ServerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int         @default(0)

  @@unique([serverId, groupId])
  @@index([groupId])
}

// ── Server Tags ────────────────────────────────────────

model ServerTag {
  id          Int                   @id @default(autoincrement())
  name        String
  color       String                @default("#4f8ef7")
  ownerId     Int
  owner       User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  assignments ServerTagAssignment[]
  createdAt   DateTime              @default(now())

  @@unique([ownerId, name])
  @@index([ownerId])
}

model ServerTagAssignment {
  id       Int       @id @default(autoincrement())
  serverId Int
  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  tagId    Int
  tag      ServerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([serverId, tagId])
  @@index([tagId])
}

// ── Server Health ──────────────────────────────────────

model ServerHealthSnapshot {
  id          String   @id @default(cuid())
  serverId    Int
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuPercent  Float
  memPercent  Float
  diskPercent Float
  memTotalMb  Float    @default(0)
  memUsedMb   Float    @default(0)
  diskTotalGb Float    @default(0)
  diskUsedGb  Float    @default(0)
  loadAvg1    Float    @default(0)
  loadAvg5    Float    @default(0)
  loadAvg15   Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([serverId, createdAt])
}

model HealthAlert {
  id        Int      @id @default(autoincrement())
  serverId  Int
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  metric    String
  threshold Float
  direction String   @default("above")
  active    Boolean  @default(true)
  ownerId   Int
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([serverId])
  @@index([ownerId])
}

// ── Display Order ──────────────────────────────────────

model ServerDisplayOrder {
  id        Int    @id @default(autoincrement())
  userId    Int
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  serverId  Int
  server    Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  context   String
  sortOrder Int    @default(0)

  @@unique([userId, serverId, context])
  @@index([userId, context, sortOrder])
}
